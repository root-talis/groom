#!/usr/bin/env bash
# Verify semver release tags match crate versions and have CHANGELOG.md sections.
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

semver_tag_re='^v?[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?(\+[0-9A-Za-z.-]+)?$'
release_tag_re='^v[0-9]+\.[0-9]+\.[0-9]+$'

package_version() {
	local manifest="$1"
	grep -m1 '^version[[:space:]]*=' "$manifest" \
		| sed -E 's/^version[[:space:]]*=[[:space:]]*"([^"]+)".*/\1/'
}

normalize_tag_version() {
	local tag="$1"
	if [[ "$tag" == v* ]]; then
		echo "${tag#v}"
	else
		echo "$tag"
	fi
}

check_tag_version() {
	local tag="$1"
	local expected
	expected="$(normalize_tag_version "$tag")"

	local groom_version groom_macros_version
	groom_version="$(package_version groom/Cargo.toml)"
	groom_macros_version="$(package_version groom_macros/Cargo.toml)"

	local mismatches=()
	if [[ "$groom_version" != "$expected" ]]; then
		mismatches+=("groom/Cargo.toml has version ${groom_version}, expected ${expected}")
	fi
	if [[ "$groom_macros_version" != "$expected" ]]; then
		mismatches+=("groom_macros/Cargo.toml has version ${groom_macros_version}, expected ${expected}")
	fi

	if ((${#mismatches[@]} > 0)); then
		echo "error: tag '${tag}' does not match crate versions:" >&2
		for mismatch in "${mismatches[@]}"; do
			echo "  - ${mismatch}" >&2
		done
		return 1
	fi
}

check_changelog_section() {
	local tag="$1"

	if [[ ! -f CHANGELOG.md ]]; then
		echo "error: CHANGELOG.md not found; required for release tag '${tag}'" >&2
		return 1
	fi

	if ! awk -v tag="$tag" '
		BEGIN { found=0; printed=0 }
		/^## v[0-9]+\.[0-9]+\.[0-9]+$/ {
			if (found) exit
			if ($0 == "## " tag) found=1
			next
		}
		found {
			if ($0 !~ /^[[:space:]]*$/) printed=1
		}
		END { exit(printed ? 0 : 1) }
	' CHANGELOG.md; then
		echo "error: CHANGELOG.md has no non-empty section for tag '${tag}'" >&2
		echo "  Add a '## ${tag}' section with release notes before pushing the tag." >&2
		return 1
	fi
}

while read -r local_ref local_sha _remote_ref _remote_sha; do
	# Skip ref deletions.
	if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
		continue
	fi

	if [[ "$local_ref" != refs/tags/* ]]; then
		continue
	fi

	tag="${local_ref#refs/tags/}"
	if [[ ! "$tag" =~ $semver_tag_re ]]; then
		continue
	fi

	check_tag_version "$tag"

	if [[ "$tag" =~ $release_tag_re ]]; then
		check_changelog_section "$tag"
	fi
done
